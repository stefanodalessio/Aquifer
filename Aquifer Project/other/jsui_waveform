mgraphics.init();
mgraphics.relative_coords = 0;
mgraphics.autofill = 0;

// Default settings:
var bufferName = "defaultBuffer";
var ampMin = -1;         // Minimum amplitude for y-range mapping
var ampMax = 1;          // Maximum amplitude for y-range mapping
var waveformColor = [0, 0, 0, 1]; // Default color: black
var thinningThreshold = 0.25; // Bin width in pixels for binning

function onmouse() { return 0; }

function paint() {
    var width = mgraphics.size[0],
        height = mgraphics.size[1];

    // Clear drawing area
    with(mgraphics) {
        set_source_rgba(0, 0, 0, 0);
        rectangle(0, 0, width, height);
        fill();
    }

    var buf = new Buffer(bufferName);
    if (!buf) return;
    var totalFrames = buf.framecount();
    if (totalFrames < 2) return;

    var startSample = 0,
        endSample = totalFrames - 1,
        numSamples = endSample - startSample + 1,
        deltaAmp = ampMax - ampMin,
        invBinWidth = 1 / thinningThreshold;

    // Calculate bin positions covering full width
    var binCount = Math.ceil(width * invBinWidth);
    var actualBinWidth = width / binCount;
    var bins = new Array(binCount);
    for (var i = 0; i < bins.length; i++) bins[i] = [];

    // Populate bins with samples
    for (var i = startSample; i <= endSample; i++) {
        var sample = buf.peek(1, i);
        var normalized = (sample - ampMin) / deltaAmp;
        var y = height - (normalized * height);
        var x = ((i - startSample) / (numSamples - 1)) * width;
        var xBin = Math.min(Math.floor(x * invBinWidth), binCount - 1);
        bins[xBin].push(y);
    }

    var points = [];
    
    // Process bins to find min/max
    for (var b = 0; b < bins.length; b++) {
        var bin = bins[b];
        if (bin.length === 0) continue;
        
        var minY = Math.min.apply(null, bin);
        var maxY = Math.max.apply(null, bin);
        
        // Ensure minimum 1px thickness if needed
        if (minY === maxY) {
            minY = Math.max(minY - 0.5, 0);
            maxY = Math.min(maxY + 0.5, height);
        }
        
        // Calculate x position spanning full width
        var xStart = b * actualBinWidth;
        var xEnd = (b + 1) * actualBinWidth;
        var xCenter = (xStart + xEnd) / 2;
        points.push({ x: xCenter, max: maxY, min: minY });
    }

    // Ensure coverage of full width
    if (points.length > 0) {
        points[0].x = 0;
        points[points.length-1].x = width;
    }

    // Sort points by x-coordinate
    points.sort(function(a, b) { return a.x - b.x; });

    with(mgraphics) {
        set_source_rgba(waveformColor[0], waveformColor[1], 
                       waveformColor[2], waveformColor[3]);
        set_line_cap("round");
        set_line_join("round");

        if (points.length > 0) {
            // Create smooth path for maxima
            move_to(points[0].x, points[0].max);
            for (var i = 1; i < points.length; i++) {
                var p0 = points[Math.max(i-2, 0)];
                var p1 = points[i-1];
                var p2 = points[i];
                var p3 = points[Math.min(i+1, points.length-1)];
                
                // Use .max property for upper curve
                var cp1x = p1.x + (p2.x - p0.x)/6;
                var cp1y = p1.max + (p2.max - p0.max)/6;
                var cp2x = p2.x - (p3.x - p1.x)/6;
                var cp2y = p2.max - (p3.max - p1.max)/6;
                
                curve_to(cp1x, cp1y, cp2x, cp2y, p2.x, p2.max);
            }
            
            // Transition to minima
            line_to(points[points.length-1].x, points[points.length-1].min);
            
            // Create smooth path for minima in reverse
            for (var i = points.length-2; i >= 0; i--) {
                var p0 = points[Math.min(i+2, points.length-1)];
                var p1 = points[i+1];
                var p2 = points[i];
                var p3 = points[Math.max(i-1, 0)];
                
                // Use .min property for lower curve
                var cp1x = p1.x + (p2.x - p0.x)/6;
                var cp1y = p1.min + (p2.min - p0.min)/6;
                var cp2x = p2.x - (p3.x - p1.x)/6;
                var cp2y = p2.min - (p3.min - p1.min)/6;
                
                curve_to(cp1x, cp1y, cp2x, cp2y, p2.x, p2.min);
            }
            
            close_path();
            fill();
        }
    }
}
// Setter functions remain unchanged
function setBufferName(name) { bufferName = name; mgraphics.redraw(); }
function definerange(min, max) { ampMin = min; ampMax = max; mgraphics.redraw(); }
function definecolor(r, g, b, a) { waveformColor = [r, g, b, arguments.length < 4 ? 1 : a]; mgraphics.redraw(); }
function definethreshold(val) { thinningThreshold = val; mgraphics.redraw(); }
function bang() { mgraphics.redraw(); }